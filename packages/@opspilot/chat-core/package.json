{
  "name": "@opspilot/chat-core",
  "version": "1.0.0",
  "description": "Pure TypeScript chat SDK with zero UI dependencies",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "chat",
    "ai",
    "typescript",
    "sse",
    "streaming",
    "opspilot"
  ],
  "author": "OpsPilot Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opspilot/chat-sdk"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^23.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}