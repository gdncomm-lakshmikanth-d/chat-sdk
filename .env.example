# Example environment variables for OpsPilot Chat SDK
# Copy this file to .env and fill in your actual values

# Agent API Configuration
AGENT_API_TOKEN=your-agent-api-token-here
AGENT_API_BASE_URL=http://localhost:9095
AGENT_API_TEAM=your-team-name

# React App Environment Variables (for frontend)
REACT_APP_API_TOKEN=your-frontend-api-token-here
REACT_APP_API_BASE_URL=https://api.example.com

# Optional: Other API configurations
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here