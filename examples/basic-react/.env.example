# Agent API Configuration
# Copy this file to .env and update with your values

# Base URL for your Agent API
VITE_AGENT_API_BASE_URL=http://localhost:9095

# Team name for Agent API
VITE_AGENT_API_TEAM=gdn-tms

# Optional: Authorization token for Agent API
# VITE_AGENT_API_TOKEN=your-token-here

# Optional: Authorization token for other SSE APIs
# VITE_API_TOKEN=your-api-token-here